{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/", "has": [{ "type": "host", "value": "www.atyant.in" }], "destination": "https://atyant.in/home", "permanent": true },
    { "source": "/:path*", "has": [{ "type": "host", "value": "www.atyant.in" }], "destination": "https://atyant.in/:path*", "permanent": true }
  ],
  "rewrites": {
    "beforeFiles": [
      { "source": "/", "destination": "https://atyantproduct.vercel.app/" },
      { "source": "/product-assets/:path*", "destination": "https://atyantproduct.vercel.app/product-assets/:path*" }
    ],
    "afterFiles": [
      { "source": "/(.*)", "destination": "/index.html" }
    ]
  }
}
